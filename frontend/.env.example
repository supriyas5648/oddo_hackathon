# The full API base URL — the ONLY thing that changes between environments.
# It must include the /api/v1 prefix (that's where the backend mounts routes).

# Local backend:
VITE_API_URL=http://localhost:5000/api/v1

# Deployed backend (Render):
# VITE_API_URL=https://assetflow-backend-3vfk.onrender.com/api/v1
