{
  "info": {
    "name": "AssetFlow — Organization Setup",
    "description": "Departments, Categories, and Users CRUD for the AssetFlow backend. Set {{baseUrl}} if your server is not on localhost:5000. Created IDs are auto-captured into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "departmentId", "value": "" },
    { "key": "childDepartmentId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Health & Index",
      "item": [
        {
          "name": "Health check",
          "request": { "method": "GET", "url": { "raw": "http://localhost:5000/health", "protocol": "http", "host": ["localhost"], "port": "5000", "path": ["health"] } }
        },
        {
          "name": "API index",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}", "host": ["{{baseUrl}}"] } }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "Create department",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) { pm.collectionVariables.set('departmentId', res.data._id); }",
                  "pm.test('201 created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Finance\",\n  \"code\": \"FIN\",\n  \"description\": \"Handles budgets and payroll\",\n  \"status\": \"Active\"\n}" },
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] }
          }
        },
        {
          "name": "Create sub-department",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) { pm.collectionVariables.set('childDepartmentId', res.data._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Payroll\",\n  \"code\": \"PAY\",\n  \"parentDepartment\": \"{{departmentId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] }
          }
        },
        {
          "name": "List departments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/departments?page=1&limit=10&sort=-createdAt&status=Active&search=fin",
              "host": ["{{baseUrl}}"],
              "path": ["departments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "-createdAt" },
                { "key": "status", "value": "Active" },
                { "key": "search", "value": "fin" }
              ]
            }
          }
        },
        {
          "name": "Department tree",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/departments/tree", "host": ["{{baseUrl}}"], "path": ["departments", "tree"] } }
        },
        {
          "name": "Get department by id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/departments/{{departmentId}}", "host": ["{{baseUrl}}"], "path": ["departments", "{{departmentId}}"] } }
        },
        {
          "name": "Update department",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\",\n  \"status\": \"Inactive\"\n}" },
            "url": { "raw": "{{baseUrl}}/departments/{{departmentId}}", "host": ["{{baseUrl}}"], "path": ["departments", "{{departmentId}}"] }
          }
        },
        {
          "name": "Delete department",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/departments/{{childDepartmentId}}", "host": ["{{baseUrl}}"], "path": ["departments", "{{childDepartmentId}}"] } }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) { pm.collectionVariables.set('categoryId', res.data._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Laptops\",\n  \"description\": \"Portable computers\",\n  \"icon\": \"laptop\",\n  \"requiresWarranty\": true,\n  \"isSharedResource\": false\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/categories?page=1&limit=10&requiresWarranty=true",
              "host": ["{{baseUrl}}"],
              "path": ["categories"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "requiresWarranty", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Get category by id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories", "{{categoryId}}"] } }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"isSharedResource\": true\n}" },
            "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories", "{{categoryId}}"] }
          }
        },
        {
          "name": "Delete category",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["categories", "{{categoryId}}"] } }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data._id) { pm.collectionVariables.set('userId', res.data._id); }",
                  "pm.test('password not returned', () => pm.expect(res.data.password).to.be.undefined);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@corp.io\",\n  \"password\": \"secret123\",\n  \"role\": \"Asset Manager\",\n  \"department\": \"{{departmentId}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10&role=Asset Manager",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "role", "value": "Asset Manager" }
              ]
            }
          }
        },
        {
          "name": "Get user by id",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] } }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"Department Head\",\n  \"status\": \"Active\"\n}" },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "Delete user",
          "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] } }
        }
      ]
    }
  ]
}
