# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/assetflow

# CORS (comma-separated list of allowed origins; * allows all)
CORS_ORIGIN=*

# Password hashing
BCRYPT_SALT_ROUNDS=10

# Authentication (Manager JWT)
# REQUIRED in production. Use a long, random string.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h
# Idle-occupied single session auto-release window in ms (default 12h).
SESSION_TTL_MS=43200000
